<resources>

    <style name="AppTheme.NoActionBar" parent="AppTheme">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:navigationBarColor">?attr/android:colorBackground</item>
    </style>


    <style name="HiddenWindowShortcutSyncStartTheme" parent="android:Theme">
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowDisablePreview">true</item>

        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <style name="DialogThemeFullScreen">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">false</item>
    </style>



    <!-- Layout Styles _____ Begin -->
    <!-- Card Styles need to be applied to the card directly.-->
    <style name="MainViewToolbar">
        <item name="cardBackgroundColor">?attr/colorPrimary</item>
        <item name="android:textColor">?attr/colorOnSecondary</item>
        <item name="android:tint">?attr/colorOnSecondary</item>
        <item name="tint">?attr/colorOnSecondary</item>
        <item name="iconTint">?attr/colorOnSecondary</item>
        <item name="actionMenuTextColor">?attr/colorOnSecondary</item>
        <item name="android:actionMenuTextColor">?attr/colorOnSecondary</item>
        <item name="popupTheme">@style/MainViewToolbarOverflowMenu</item>
        <item name="android:textColorPrimary">?attr/colorOnSecondary</item>
    </style>

    <style name="MainViewToolbarOverflowMenu" parent="ThemeOverlay.AppCompat.Dark.ActionBar">
        <item name="android:colorBackground">?attr/colorSecondary</item>
        <item name="android:textColor">?attr/colorSecondary</item>
        <item name="android:textColorPrimary">?attr/colorSecondary</item>
    </style>

    <style name="FloatingActionButtonMulti">
        <item name="colorAccent">?attr/colorPrimaryContainer</item>
    </style>

    <style name="FileListItem">
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:tint">?attr/colorOnSurface</item>
    </style>

    <style name="FileListItemDescription">
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
        <item name="android:tint">?attr/colorOnSurfaceVariant</item>
    </style>

    <style name="FileListBottomBars">
        <item name="android:textColor">?attr/colorOnTertiary</item>
        <item name="android:tint">?attr/colorOnTertiary</item>
        <item name="android:background">?attr/colorTertiary</item>
        <item name="cardBackgroundColor">?attr/colorTertiary</item>
    </style>

    <style name="SettingsTheme">
        <item name="android:textColor">?attr/colorOnBackground</item>
        <item name="android:tint">?attr/colorOnBackground</item>
    </style>

    <!-- Card Styles need to be applied to the card directly.-->
    <style name="PrimaryCardStyle">
        <item name="cardBackgroundColor">?attr/colorPrimaryContainer</item>
        <item name="android:textColor">?attr/colorOnPrimaryContainer</item>
        <item name="android:tint">?attr/colorOnPrimaryContainer</item>
    </style>

    <style name="Widget.Courier.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">20dp</item>
        <item name="contentPadding">20dp</item>
    </style>

    <style name="Widget.Courier.Card.Outlined" parent="Widget.Material3.CardView.Outlined">
        <item name="cardCornerRadius">20dp</item>
        <item name="contentPadding">16dp</item>
    </style>

    <style name="Widget.Courier.Card.Elevated" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">20dp</item>
        <item name="contentPadding">16dp</item>
    </style>

    <style name="Widget.Courier.Card.ListItem" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">18dp</item>
        <item name="cardBackgroundColor">?attr/colorSurfaceVariant</item>
        <item name="android:layout_marginStart">12dp</item>
        <item name="android:layout_marginEnd">12dp</item>
        <item name="android:layout_marginTop">6dp</item>
        <item name="android:layout_marginBottom">6dp</item>
    </style>

    <style name="Widget.Courier.Button" parent="Widget.Material3.Button">
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <style name="Widget.Courier.Button.Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <style name="Widget.Courier.Button.Text" parent="Widget.Material3.Button.TextButton" />

    <style name="Widget.Courier.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton" />

    <style name="Widget.Courier.Switch" parent="Widget.Material3.CompoundButton.MaterialSwitch" />

    <style name="TextAppearance.Courier.SectionHeader" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="TextAppearance.Courier.EmptyTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="TextAppearance.Courier.EmptySubtitle" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    </style>

    <style name="SecondaryCardStyle">
        <item name="cardBackgroundColor">?attr/colorSecondaryContainer</item>
        <item name="android:textColor">?attr/colorOnSecondaryContainer</item>
        <item name="android:tint">?attr/colorOnSecondaryContainer</item>
    </style>

    <style name="RoundedCornersDialog" parent="@style/MaterialAlertDialog.MaterialComponents">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearanceOverlay.Dialog.Rounded</item>
        <item name="android:padding">@dimen/dialogPadding</item>
    </style>
    <style name="ShapeAppearanceOverlay.Dialog.Rounded" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/dialogCornerRadius</item>
    </style>
    <style name="BreadcrumbText" parent="">
        <item name="android:textColor">@color/md_theme_light_background</item>
    </style>
</resources>
